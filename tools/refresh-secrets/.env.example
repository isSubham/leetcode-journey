# ── GitHub Personal Access Token ────────────────────────────────────────────
# Create a fine-grained PAT at: https://github.com/settings/tokens?type=beta
# Scope it to ONLY this repo, with ONLY "Secrets: write" permission.
# Do not use a classic PAT — full repo scope is unnecessarily broad.
GITHUB_PAT=

# ── Repository details ───────────────────────────────────────────────────────
# Your GitHub username (the short handle in your profile URL, not your email).
GITHUB_OWNER=

# The exact repo name as it appears in the URL.
# e.g. if your repo is github.com/alice/leetcode-journey → set this to leetcode-journey
GITHUB_REPO=leetcode-journey
